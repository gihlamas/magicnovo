# ============================================
# MagicFlow - Variáveis de Ambiente
# ============================================

# Banco de Dados (OBRIGATÓRIO)
DATABASE_URL=postgresql://user:password@localhost:5432/magicflow
# Alternativa para MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/magicflow

# WhatsApp (Meta Cloud API) - OBRIGATÓRIO
WHATSAPP_TOKEN=seu_token_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui
WHATSAPP_ACCESS_TOKEN=seu_access_token_aqui
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao_aqui
WHATSAPP_API_VERSION=v19.0

# OpenAI (OBRIGATÓRIO)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-mini
OPENAI_MAX_TOKENS=500

# MagicAds (Opcional)
MAGICADS_API_KEY=sua_chave_aqui

# Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Banco de Dados - Configuração Alternativa (se não usar DATABASE_URL)
# DB_DIALECT=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=magicflow
# DB_USER=postgres
# DB_PASSWORD=sua_senha
# DB_SSL=false

# Follow-up Scheduler (em minutos)
FOLLOWUP_DELAY_1=10
FOLLOWUP_DELAY_2=60
FOLLOWUP_DELAY_3=1440
FOLLOWUP_MAX_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
